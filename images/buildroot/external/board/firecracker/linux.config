# Minimal kernel config for Firecracker microVMs. Targets Linux 6.6.x.
# Built on top of the kernel's stock x86_64 defconfig assumptions —
# this file is the FULL .config used during build (Buildroot copies
# it verbatim), not a fragment.
#
# Drivers required for Firecracker's virtual hardware:
#   virtio_blk (rootfs), virtio_net (egress), virtio_pci (transport),
#   virtio_vsock (host↔guest control channel), virtio_console (logs).
# Filesystems: ext4 (rootfs), tmpfs (transient), proc + sysfs.
# No PCI hotplug, no USB, no audio, no graphics, no firmware blobs.
#
# Kept intentionally short — anything we don't list here defaults to
# off. The full kernel build then activates required dependencies.

CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_KVM_GUEST=y

# Block + filesystems
CONFIG_BLK_DEV=y
CONFIG_VIRTIO_BLK=y
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Networking + virtio
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y

# Vsock — the host-guest control channel the supervisor + agent use.
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y

# Serial console — Firecracker's primary log channel.
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# Process model + init
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_PRINTK=y
CONFIG_EARLY_PRINTK=y

# Random number generator (Firecracker exposes virtio-rng).
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y

# Power off (Firecracker handles ACPI shutdown).
CONFIG_ACPI=y
