# NeuronEdge Enclave runtime configuration. Sourced by both systemd units.
#
# ============================ SECURITY ============================
# API-key authentication (wedge 6.6) gates gRPC + REST. In-process TLS
# (wedge 6.7) is available via NE_TLS_CERT / NE_TLS_KEY below.
# This reference deployment ships in dev-mode bound to localhost; before
# exposing the API, set NE_DEV_MODE=false, configure an API key
# (`nee api-key generate --key-file /etc/ne-enclave/api-keys`) AND either
# set the TLS cert/key below or
# terminate TLS at a reverse proxy and keep the binds on loopback.
# ==================================================================

# --- In-process TLS (optional; required for a non-loopback bind in prod) ---
# NE_TLS_CERT=/etc/ne-enclave/tls/cert.pem
# NE_TLS_KEY=/etc/ne-enclave/tls/key.pem

# --- API front door (unprivileged) ---
NE_API_BIND=127.0.0.1:50051
NE_REST_BIND=127.0.0.1:8080
NE_DEV_MODE=true

# --- Supervisor IPC (real peer-cred auth: the ne service uid) ---
NE_SUPERVISOR_SOCKET=/run/ne-enclave/supervisor.sock
NE_SUPERVISOR_PEER_UID=__NE_UID__

# --- Host binaries + jailer ---
NE_FIRECRACKER_BIN=/opt/ne-enclave/bin/firecracker
NE_JAILER_BIN=/opt/ne-enclave/bin/jailer
NE_JAILER_CHROOT_BASE=/srv/jailer
NE_STATE_DIR=/var/lib/ne-enclave
NE_IMAGE_STORE=/var/lib/ne-enclave/images

# --- Guest image (content-addressed; set by `nee install`) ---
# NOTE: NE_KERNEL_PATH and NE_ROOTFS_PATH are informational only.
# CreateWorkspace supplies canonical kernel/rootfs digests; the supervisor
# resolves them beneath NE_IMAGE_STORE. These lines only document the
# artifacts imported by `nee install`.
NE_KERNEL_PATH=__KERNEL_PATH__
NE_ROOTFS_PATH=__ROOTFS_PATH__

# --- Networking (off by default; enable per ARCH 4.7) ---
NE_ENABLE_NETWORKING=false
NE_DNS_FILTER_BIN=/opt/ne-enclave/bin/nee
# Privacy router: both BIN and POLICY must be set or the per-workspace
# router is not spawned (even for enable_privacy_router workspaces). The
# policy is installed by `nee install` to the path below; point this at a
# custom YAML to enforce your own entity actions.
NE_PRIVACY_ROUTER_BIN=/opt/ne-enclave/bin/nee
NE_PRIVACY_ROUTER_POLICY=/etc/ne-enclave/privacy-policy.yaml
