{
  "name": "@neuronedge/enclave",
  "version": "0.1.0",
  "description": "TypeScript SDK for the NeuronEdge Enclave Runtime API.",
  "license": "Apache-2.0",
  "author": "Infrastacks LLC <eng@infrastacks.com>",
  "homepage": "https://neuronedge.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Infrastacks/ne-enclave.git"
  },
  "keywords": [
    "enclave",
    "firecracker",
    "microvm",
    "confidential-computing",
    "agent",
    "grpc",
    "runtime"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "codegen": "bash codegen.sh",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.0.0",
    "grpc-tools": "^1.12.0",
    "ts-proto": "^2.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
